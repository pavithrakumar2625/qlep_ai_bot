NODE_ENV=development
API_PORT=4000
PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ADMIN_ORIGIN=http://localhost:3000

# Database (Postgres)
DATABASE_URL=postgres://qelp:qelp@localhost:5432/qelp

# Auth (must be at least 32 chars and not the default outside development)
AUTH_SECRET=change-me-in-local-dev

# AI providers (leave empty to use the deterministic fallback)
OPENAI_API_KEY=
GROQ_API_KEY=
AI_PROVIDER=auto
OPENAI_MODEL=gpt-4o-mini
GROQ_MODEL=openai/gpt-oss-20b
AI_REASONING_EFFORT=low
AI_TIMEOUT_MS=20000

# Speech-to-text (used when audio attachments are present)
STT_PROVIDER=none
STT_MODEL=whisper-1

# Storage (local filesystem in dev)
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=./storage

# Logging + rate limits
LOG_LEVEL=info
RATE_LIMIT_FEEDBACK_PER_MIN=30
RATE_LIMIT_LOGIN_PER_MIN=10
