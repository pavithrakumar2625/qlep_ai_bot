{
  "name": "@qelp/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "db:up": "docker compose -f ../../docker-compose.yml up -d postgres",
    "db:down": "docker compose -f ../../docker-compose.yml down",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:reset": "docker compose -f ../../docker-compose.yml down -v && npm run db:up && sleep 2 && npm run db:migrate && npm run db:seed",
    "db:generate": "drizzle-kit generate",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --pool threads --poolOptions.threads.singleThread"
  },
  "dependencies": {
    "@qelp/shared": "0.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "postgres": "^3.4.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "drizzle-kit": "^0.30.1",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
