{
  "name": "qelp",
  "version": "0.1.0",
  "private": true,
  "description": "AI-first feedback and bug triage platform for agencies.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace @qelp/api",
    "dev:admin": "npm run dev --workspace @qelp/admin",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
